{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Justsent",
  "version": "0.1.0",
  "identifier": "com.adityakashyap.justsent",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "bunx concurrently -k \"bun run dev\" \"cd ../backend && go run main.go\""
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "bun run build"
    },
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 860,
        "height": 560,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
